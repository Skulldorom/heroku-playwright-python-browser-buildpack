#!/usr/bin/env bash
set -euo pipefail

BUILD_DIR=${1:-.}

if [ -f "$BUILD_DIR/pyproject.toml" ] || [ -f "$BUILD_DIR/uv.lock" ] || [ -f "$BUILD_DIR/requirements.txt" ] || [ -f "$BUILD_DIR/poetry.lock" ]; then
  echo "Playwright Python browser installer"
  exit 0
fi

echo "Playwright Python browser installer: Python app not detected" >&2
exit 1
